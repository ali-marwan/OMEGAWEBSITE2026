# OMEGA — environment variables
#
# Copy this file to `.env.local` for local development, or configure
# the values in your hosting provider (Vercel: Project → Settings →
# Environment Variables) for preview / production deployments.
#
# Every variable below is `NEXT_PUBLIC_*` because it is intentionally
# exposed to the browser (canonical URL, contact placeholders shown
# in the UI). Do NOT add real backend secrets — Supabase keys, CRM
# tokens, WhatsApp Business credentials — to NEXT_PUBLIC_* vars.
# Server-only secrets must use plain `<NAME>` (no NEXT_PUBLIC_ prefix).

# ─── Canonical site URL ───────────────────────────────────────────
# Used for canonical URLs, the sitemap, robots.txt, Open Graph tags,
# Twitter cards, and JSON-LD structured-data URLs.
#
# TODO: Replace this Vercel preview URL with the final production
# domain before official launch (e.g. https://omega.ae).
#
# When unset, the application falls back to the Vercel-stamped URL,
# then to the hard fallback below.
NEXT_PUBLIC_SITE_URL=https://omegawebsite-2026.vercel.app

# ─── Operational contact placeholders ─────────────────────────────
# These render visibly on /contact and in the footer. Until the
# operations team confirms real values, the application renders the
# literal placeholder strings so QA + visitors immediately see the
# gap.
#
# TODO: Replace each value with the real operational contact before
# launch. The literal placeholder strings ("TODO_PHONE", etc.) are
# intentionally non-functional — clicking a `mailto:TODO_EMAIL` link
# does not open a mail client until a real email address is set.
NEXT_PUBLIC_CONTACT_PHONE=TODO_PHONE
NEXT_PUBLIC_CONTACT_EMAIL=TODO_EMAIL
NEXT_PUBLIC_WHATSAPP_LINK=TODO_WHATSAPP_LINK

# Optional — the raw E.164 WhatsApp number (digits only, no plus
# sign, e.g. 971501234567). Used by `buildWhatsAppLink()` in
# lib/leads.ts to compose `https://wa.me/<number>?text=<encoded>`.
# Falls back to the placeholder when unset.
NEXT_PUBLIC_WHATSAPP_NUMBER=TODO_WHATSAPP_NUMBER
